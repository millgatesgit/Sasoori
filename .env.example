# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql:///sasoori_db?socketFactory=org.newsclub.net.unix.AFUNIXSocketFactory&socketFactoryArg=/var/run/postgresql/.s.PGSQL.5432
DB_USER=sasoori
DB_PASSWORD=change_me_in_production

# ── Auth ───────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# RS256 private key in PEM format (base64-encoded). Leave empty in dev (ephemeral).
JWT_PRIVATE_KEY=

# ── Dev mode (set true locally only — never in production) ────────────────────
DEV_MODE=false

# ── Frontend & Cookies ────────────────────────────────────────────────────────
FRONTEND_URL=https://sasoori.com
SECURE_COOKIE=true

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ── Shipping ──────────────────────────────────────────────────────────────────
SHIPROCKET_EMAIL=logistics@sasoori.com
SHIPROCKET_PASSWORD=your-shiprocket-password
SHIPROCKET_PICKUP_LOCATION=Primary

# ── OTP / SMS ─────────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_TEMPLATE_ID=your-msg91-template-id
FAST2SMS_API_KEY=your-fast2sms-key

# ── WhatsApp (optional) ───────────────────────────────────────────────────────
# Leave blank to disable WhatsApp notifications
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Shipping thresholds ───────────────────────────────────────────────────────
FREE_SHIPPING_THRESHOLD_PAISE=49900
SHIPPING_CHARGE_PAISE=4900
